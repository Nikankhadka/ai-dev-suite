{
  "$schema": "https://opencode.ai/config.json",
  "default_agent": "build",

  "instructions": [
    "instructions/INSTRUCTIONS.md"
  ],

  "plugin": [
    "./plugins"
  ],

  "agent": {
    "build": {
      "description": "Primary coding agent for development. Use for day-to-day coding, small fixes, and straightforward changes.",
      "mode": "primary",
      "permission": {
        "*": "allow"
      }
    },
    "planner": {
      "description": "Expert planning specialist for complex features, system design, and database schema. Use for implementation planning, architectural changes, or complex refactoring.",
      "mode": "subagent",
      "prompt": "{file:prompts/agents/planner.txt}",
      "tools": { "read": true, "bash": true, "write": false, "edit": false }
    },
    "reviewer": {
      "description": "Code quality, security, and build error resolution specialist. Reviews code for quality, security vulnerabilities, and fixes TypeScript/build errors. Use after writing code, for security audit, or when build fails.",
      "mode": "subagent",
      "prompt": "{file:prompts/agents/reviewer.txt}",
      "tools": { "read": true, "write": true, "edit": true, "bash": true }
    },
    "tdd-guide": {
      "description": "Test-Driven Development specialist enforcing write-tests-first methodology. Use when writing new features, fixing bugs, or refactoring code.",
      "mode": "subagent",
      "prompt": "{file:prompts/agents/tdd-guide.txt}",
      "tools": { "read": true, "write": true, "edit": true, "bash": true }
    },
    "e2e-runner": {
      "description": "End-to-end testing specialist using Playwright. Generates, maintains, and runs E2E tests for critical user flows.",
      "mode": "subagent",
      "prompt": "{file:prompts/agents/e2e-runner.txt}",
      "tools": { "read": true, "write": true, "edit": true, "bash": true }
    },
    "maintainer": {
      "description": "Code maintenance and documentation specialist. Removes dead code, consolidates duplicates, updates documentation and codemaps.",
      "mode": "subagent",
      "prompt": "{file:prompts/agents/maintainer.txt}",
      "tools": { "read": true, "write": true, "edit": true, "bash": true }
    },
    "ops": {
      "description": "Operations, orchestration, memory, and system control specialist. Handles multi-agent pipelines, instinct management, harness optimization, loop operations, project setup, and documentation lookup.",
      "mode": "subagent",
      "prompt": "{file:prompts/agents/ops.txt}",
      "tools": { "read": true, "bash": true, "edit": true }
    }
  },

  "command": {
    "plan": {
      "description": "Create a detailed implementation plan with architecture and database design",
      "template": "{file:commands/plan.md}\n\n$ARGUMENTS",
      "agent": "planner",
      "subtask": true
    },
    "tdd": {
      "description": "Enforce TDD workflow with 80%+ test coverage or analyze coverage",
      "template": "{file:commands/tdd.md}\n\n$ARGUMENTS",
      "agent": "tdd-guide",
      "subtask": true
    },
    "review": {
      "description": "Review code for quality, security, and fix build/TypeScript errors",
      "template": "{file:commands/review.md}\n\n$ARGUMENTS",
      "agent": "reviewer",
      "subtask": true
    },
    "e2e": {
      "description": "Generate and run E2E tests with Playwright",
      "template": "{file:commands/e2e.md}\n\n$ARGUMENTS",
      "agent": "e2e-runner",
      "subtask": true
    },
    "maintain": {
      "description": "Clean dead code, consolidate duplicates, and update documentation",
      "template": "{file:commands/maintain.md}\n\n$ARGUMENTS",
      "agent": "maintainer",
      "subtask": true
    },
    "orchestrate": {
      "description": "Orchestrate multiple agents for complex tasks",
      "template": "{file:commands/orchestrate.md}\n\n$ARGUMENTS",
      "agent": "ops",
      "subtask": true
    },
    "memory": {
      "description": "Manage instincts, skills, and project memory",
      "template": "{file:commands/memory.md}\n\n$ARGUMENTS",
      "agent": "ops",
      "subtask": true
    },
    "system": {
      "description": "Harness, loops, project setup, and model routing",
      "template": "{file:commands/system.md}\n\n$ARGUMENTS",
      "agent": "ops",
      "subtask": true
    },
    "eval": {
      "description": "Run evaluation, verification, and quality gates",
      "template": "{file:commands/eval.md}\n\n$ARGUMENTS",
      "agent": "ops",
      "subtask": true
    },
    "docs": {
      "description": "Look up current library/framework documentation via Context7 MCP",
      "template": "{file:commands/docs.md}\n\n$ARGUMENTS",
      "agent": "ops",
      "subtask": true
    }
  },

  "permission": "allow",

  "lsp": true,

  "mcp": {
    "context7": {
      "type": "remote",
      "url": "https://mcp.context7.com/mcp",
      "enabled": true
    },
    "gh_grep": {
      "type": "remote",
      "url": "https://mcp.grep.app",
      "enabled": true
    }
  }
}
