{
  "$schema": "https://opencode.ai/config.json",
  "default_agent": "build",

  "instructions": [
    "instructions/AGENTS.md"
  ],

  "permission": "allow",

  "lsp": true,

  "mcp": {
    "context7": {
      "type": "remote",
      "url": "https://mcp.context7.com/mcp",
      "enabled": true
    },
    "gh_grep": {
      "type": "remote",
      "url": "https://mcp.grep.app",
      "enabled": true
    }
  }
}
